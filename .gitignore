# ═══════════════════════════════════════════════════════════
#  YACHAY LAB — .gitignore
#  Protege claves, dependencias y archivos innecesarios
# ═══════════════════════════════════════════════════════════


# ─── 🔴 CRÍTICO: Claves y secretos ──────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
config/.env
config/.env.local
*.key
*.pem
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml


# ─── Node.js ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnp
.pnp.js


# ─── Build / Dist ────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/


# ─── IDEs y editores ─────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ─── Logs ────────────────────────────────────────────────
logs/
*.log
*.log.*


# ─── Sistema operativo ───────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ─── Testing ─────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov


# ─── Temporales ──────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig


# ─── Archivos de deploy (solo si no los quieres en repo) ─
# Descomenta si no quieres subir estos:
# vercel.json
# netlify.toml
# railway.json